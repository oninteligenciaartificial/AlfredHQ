# =============================================================================
# Alfred — Environment Variables Example
# Copy to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Claude API (Anthropic)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Meta / Instagram
# -----------------------------------------------------------------------------
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
# Webhook verification token (any random string you define)
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# -----------------------------------------------------------------------------
# TikTok
# -----------------------------------------------------------------------------
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# -----------------------------------------------------------------------------
# LinkedIn
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# -----------------------------------------------------------------------------
# n8n (automation server)
# -----------------------------------------------------------------------------
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret
# Used to verify that POST requests to /api/agent/tasks/generate and
# /api/sync/analytics and /api/posts/publish come from your n8n instance.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production: https://yourdomain.com

# -----------------------------------------------------------------------------
# Telegram (future: Phase 2 alerts)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_DEFAULT_CHAT_ID=your-chat-id

# -----------------------------------------------------------------------------
# WhatsApp Business (future: Phase 3 alerts)
# -----------------------------------------------------------------------------
# WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-whatsapp-webhook-verify-token

# -----------------------------------------------------------------------------
# Discord (future: Phase 3 alerts)
# -----------------------------------------------------------------------------
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# -----------------------------------------------------------------------------
# QR Payments (future: Phase 2)
# -----------------------------------------------------------------------------
# QR_SIGNING_KEY=your-qr-signing-secret
# QR_PROVIDER=simple-pos  # or qr-facil, pagofacil, etc.

# -----------------------------------------------------------------------------
# Billing (future: Phase 4)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Bolivia: Libélula / Culqi credentials here if used instead

# -----------------------------------------------------------------------------
# External SaaS API (future: Phase 5 — DentaGest integration)
# -----------------------------------------------------------------------------
# DENTAGEST_WEBHOOK_SECRET=your-dentagest-webhook-secret
# API_KEY_ENCRYPTION_SECRET=32-char-secret-for-encrypting-tenant-api-keys
